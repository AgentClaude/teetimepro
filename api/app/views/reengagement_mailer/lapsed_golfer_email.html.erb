<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @campaign.subject %></title>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background-color: #2c5530; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background-color: #f9f9f9; }
    .cta-button { 
      display: inline-block; 
      padding: 12px 24px; 
      background-color: #4CAF50; 
      color: white; 
      text-decoration: none; 
      border-radius: 5px; 
      font-weight: bold;
      margin: 20px 0;
    }
    .footer { padding: 20px; font-size: 12px; color: #666; text-align: center; }
    .personalization { color: #2c5530; font-weight: bold; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= @organization.name %></h1>
      <p>We Miss You on the Course!</p>
    </div>
    
    <div class="content">
      <p>Hi <span class="personalization"><%= @user.first_name || 'Fellow Golfer' %></span>,</p>
      
      <%= raw personalize_content(@campaign.body_html, @user) %>
      
      <p style="text-align: center;">
        <a href="<%= @booking_url %>" class="cta-button">Book Your Tee Time Now</a>
      </p>
      
      <p><strong>Why return to <%= @organization.name %>?</strong></p>
      <ul>
        <li>Pristine course conditions maintained daily</li>
        <li>Flexible tee time options to fit your schedule</li>
        <li>Member pricing and exclusive benefits</li>
        <li>Professional staff ready to assist you</li>
      </ul>
    </div>
    
    <div class="footer">
      <p>
        <%= @organization.name %><br>
        <%= @organization.address if @organization.address %><br>
        <%= @organization.phone if @organization.phone %>
      </p>
      
      <p>
        <a href="<%= @booking_url %>">Book Online</a> | 
        <a href="mailto:<%= @organization.email %>">Contact Us</a>
      </p>
      
      <p style="font-size: 10px; color: #999;">
        You received this email because you're a valued member of <%= @organization.name %>. 
        If you'd prefer not to receive these emails, please contact us.
      </p>
    </div>
  </div>
</body>
</html>

<% content_for :personalize_content do |content, user| %>
  <% content.gsub('{{first_name}}', user.first_name || 'Golfer')
           .gsub('{{name}}', user.full_name || 'Golfer')
           .gsub('{{golf_course}}', @organization.name) %>
<% end %>