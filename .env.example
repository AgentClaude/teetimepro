# ===========================================
# TeeTimes Pro — Environment Variables
# Copy to .env and fill in values
#
# Validate config:  cd api && bundle exec rake config:validate
# Audit env vars:   cd api && bundle exec rake config:audit
# ===========================================

# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=teetimepro_development
POSTGRES_USER=teetimepro
POSTGRES_PASSWORD=password
DATABASE_URL=postgres://teetimepro:password@db:5432/teetimepro_development
DB_HOST=db
DB_USERNAME=teetimepro
DB_PASSWORD=password
DB_NAME=teetimepro_development
DB_TEST_NAME=teetimepro_test

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SIDEKIQ_REDIS_URL=redis://redis:6379/1

# ─── Rails (REQUIRED) ──────────────────────────────────────
RAILS_ENV=development
SECRET_KEY_BASE=dev-secret-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
CORS_ORIGINS=http://localhost:3004

# ─── Ports (host-side) ─────────────────────────────────────
API_PORT=3003
WEB_PORT=3004

# ─── Stripe (optional in dev) ──────────────────────────────
# Leave blank to disable payment features in development.
# Required in production.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Twilio (optional in dev) ──────────────────────────────
# Leave blank to disable SMS features in development.
# Required in production.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Deepgram (optional) ───────────────────────────────────
# Required for voice agent features.
DEEPGRAM_API_KEY=

# ─── Frontend (Vite build-time variables) ──────────────────
VITE_API_URL=http://localhost:3003
VITE_GRAPHQL_URL=/graphql
