# ===========================================
# TeeTimes Pro — Production Environment
# Copy to .env on the production server and fill in all values
# ===========================================

# Domain (used by nginx for SSL certificate and server_name)
DOMAIN=app.teetimepro.com

# Database (use strong, unique passwords!)
POSTGRES_DB=teetimepro_production
POSTGRES_USER=teetimepro
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# Rails
RAILS_ENV=production
SECRET_KEY_BASE=CHANGE_ME_generate_with_rails_secret
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
CORS_ORIGINS=https://app.teetimepro.com

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Deepgram
DEEPGRAM_API_KEY=xxx

# Voice agent
VOICE_BOT_BASE_URL=https://app.teetimepro.com/voice
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
TTS_MODEL=aura-2-odysseus-en

# Frontend (baked into JS at build time)
VITE_API_URL=https://app.teetimepro.com
VITE_GRAPHQL_URL=/graphql

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@teetimepro.com
